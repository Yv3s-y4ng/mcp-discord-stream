{
  "name": "@yangyifei/mcp-discord-stream",
  "version": "1.4.0",
  "description": "Model Context Protocol (MCP) server for Discord with unlimited message streaming, forum archiving, and time-range filtering. Allows Claude and other MCP clients to read complete Discord history.",
  "main": "build/index.js",
  "bin": {
    "mcp-discord": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test-api": "node test-api.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "discord",
    "claude",
    "ai",
    "chatbot",
    "automation",
    "streaming",
    "archive",
    "history",
    "forum",
    "unlimited-messages"
  ],
  "author": "Barry Yip <barry99625@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Y1fe1-Yang/mcp-discord-stream.git"
  },
  "bugs": {
    "url": "https://github.com/Y1fe1-Yang/mcp-discord-stream/issues"
  },
  "homepage": "https://github.com/Y1fe1-Yang/mcp-discord-stream#readme",
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.50",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "zod": "^3.25.13"
  }
}
